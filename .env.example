# Storage backend: sqlite (default) or postgres
MOVIES_BACKEND=sqlite

# SQLite location (used when MOVIES_BACKEND=sqlite)
MOVIES_DB_PATH=movies.db

# Postgres connection (used when MOVIES_BACKEND=postgres)
# Matches the docker-compose db service; bring it up with `just db-up`.
# DATABASE_URL=postgresql+psycopg://movies:movies@localhost:5433/movies
