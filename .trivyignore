# Unfixed CVEs in the python:3.14-slim base image (Debian). None are in our
# code or used by the app at runtime, and no upstream fix is available yet.
# Each waiver expires 2026-09-01 to force a re-review — check whether a fix
# has shipped or the base image can be bumped before extending.

# ncurses buffer overflow — libncursesw6 / libtinfo6 / ncurses-base / ncurses-bin
CVE-2025-69720 exp:2026-09-01

# perl Archive::Tar symlink extraction (CRITICAL)
CVE-2026-42496 exp:2026-09-01

# perl heap buffer overflow (CRITICAL)
CVE-2026-8376 exp:2026-09-01

# perl Archive::Tar hardlink extraction
CVE-2026-42497 exp:2026-09-01

# perl Archive::Tar memory exhaustion
CVE-2026-9538 exp:2026-09-01

# perl IO::Compress eval injection via output glob
CVE-2026-48962 exp:2026-09-01

# no upstream fix as of 2026-06; revisit
CVE-2026-11822 exp:2026-09-01
CVE-2026-11824 exp:2026-09-01
CVE-2026-48959 exp:2026-09-01

# acl symlink traversal privilege escalation — libacl1 (no fix yet)
CVE-2026-54369 exp:2026-09-01

# attr symlink traversal privilege escalation — libattr1 (no fix yet)
CVE-2026-54371 exp:2026-09-01

# util-linux integer overflow in libblkid/src/partitions/dos.c — affects
# bsdutils, libblkid1, liblastlog2-2, libmount1, libsmartcols1, libuuid1,
# login, mount, util-linux (2.41-5). We never parse untrusted DOS partition
# tables; no fix yet.
CVE-2026-53615 exp:2026-09-01

# gzip global buffer overflow in the LZH decoder (1.13-1). App does not
# decompress untrusted .lzh archives; no fix yet.
CVE-2026-41992 exp:2026-09-01

# perl silently incorrect regex results through 5.43.9 (CRITICAL) — perl-base
# 5.40.1-6, no fix yet.
CVE-2026-13221 exp:2026-09-01

# perl integer overflow in S_measure_st* through 5.43.10 — perl-base
# 5.40.1-6, no fix yet.
CVE-2026-57432 exp:2026-09-01
